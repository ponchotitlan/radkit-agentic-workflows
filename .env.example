# -----------------------------------------------------------------------------
# RADKit MCP - Full-Access Instance
# -----------------------------------------------------------------------------
RADKIT_FASTMCP_HOST=0.0.0.0
RADKIT_MCP_PORT=8082
RADKIT_MCP_HOST_PORT=8082

# RADKit runtime behavior
RADKIT_SANDBOX=subprocess
RADKIT_ACCESS_MODE=full
RADKIT_AUTO_APPROVE=true
RADKIT_RESTART_POLICY=unless-stopped

# Paths mounted from the repo into the container.
RADKIT_SERVICE_CONFIG=radkit-mcp/service.config.direct
RADKIT_PROFILE=radkit-mcp/radkit-mcp-profile.py
RADKIT_PROMPT_FILE=radkit-mcp/radkit-mcp-prompt.txt

# Log configuration.
RADKIT_LOGS_HOST_DIR=./radkit-mcp/logs

# -----------------------------------------------------------------------------
# RADKit MCP - Read-only Instance
# -----------------------------------------------------------------------------
RADKIT2_MCP_PORT=8083
RADKIT2_MCP_HOST_PORT=8083

# RADKit runtime behavior
RADKIT2_SANDBOX=subprocess
RADKIT2_ACCESS_MODE=read
RADKIT2_AUTO_APPROVE=true
RADKIT2_RESTART_POLICY=unless-stopped

# Paths mounted from the repo into the container.
RADKIT2_SERVICE_CONFIG=radkit-mcp/service.config.direct
RADKIT2_PROFILE=radkit-mcp/radkit-mcp-profile.py
RADKIT2_PROMPT_FILE=radkit-mcp/radkit-mcp-prompt.txt

# Log configuration.
RADKIT2_LOGS_HOST_DIR=./radkit-mcp/logs-2

# -----------------------------------------------------------------------------
# CLOUDFLARE TUNNEL
# -----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
N8N_PUBLIC_URL=https://n8n.your-domain.example